# ── Google Cloud / Veo 3 ─────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=credentials/google_service_account.json
VEO_MODEL=veo-003                          # Google Veo 3 model name (confirm in GCP docs)
VEO_REGION=us-central1                     # GCP region supporting Veo 3

# ── TikTok API ────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_REFRESH_TOKEN=your-tiktok-refresh-token  # Initial refresh token from OAuth flow
TIKTOK_OPEN_ID=your-tiktok-open-id              # The creator's TikTok user ID
# Note: After first use, tokens are auto-refreshed and persisted to
# credentials/tiktok_tokens.json. The env vars above are only needed for
# the initial bootstrap.

# ── TikTok Sandbox (optional — use with --sandbox flag) ──────────────────────
TIKTOK_SANDBOX_CLIENT_KEY=your-sandbox-client-key
TIKTOK_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret

# ── Caption LLM (Anthropic Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key       # For LLM-generated captions
CAPTION_MODEL=claude-haiku-4-5-20251001        # Fast + cheap; any Claude model works

# ── Pipeline Settings ─────────────────────────────────────────────────────────
VIDEOS_PER_RUN=1                           # How many videos to generate per run
OUTPUT_DIR=output                          # Local directory to store generated videos
# Video duration is always 8s (single Veo 3 clip, no stitching)
DRY_RUN=false                             # true = generate but don't post

# ── Scheduling ────────────────────────────────────────────────────────────────
POST_SCHEDULE_CRON=0 18 * * *             # Default: 6 PM daily
POST_TIMEZONE=America/Los_Angeles

# ── Notifications (optional) ─────────────────────────────────────────────────
NOTIFY_EMAIL=                              # Email for run summaries (leave blank to skip)
